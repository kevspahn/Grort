# Database
DATABASE_URL=postgresql://grort:grort@localhost:5433/grort

# Node environment (set to "production" in prod — enables strict JWT_SECRET check)
NODE_ENV=development

# JWT — REQUIRED in production (server refuses to boot without it)
JWT_SECRET=change-me-in-production

# Comma-separated list of browser origins allowed by CORS (default: https://grort.app)
CORS_ORIGINS=http://localhost:8081,https://grort.app

# AI Providers (set at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_PROVIDER=claude
# Optional: override the Claude model used for receipt parsing
ANTHROPIC_MODEL=claude-sonnet-5

# S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=grort-receipts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
